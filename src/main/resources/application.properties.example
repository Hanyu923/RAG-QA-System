# 应用配置
spring.application.name=rag-qa-system

# 阿里云 DashScope API（请通过环境变量 ALIYUN_API_KEY 传入）
aliyun.api.key=${ALIYUN_API_KEY:你的阿里云API Key}
aliyun.embedding.model=text-embedding-v3
spring.ai.dashscope.api-key=${aliyun.api.key}
spring.ai.dashscope.chat.options.model=qwen-plus

# Redis 依赖已移除，改用 Caffeine 本地缓存
